[2.014, "o", "\r\n# Retrieval benchmark (20 questions, keyword matching):\r\n\r\n"]
[1.061, "o", "\r\n"]
[0.000, "o", "\u001b[1m╔═══════════════════════════════════════════════════════════════════════╗\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m║   OpenClaw Memory Benchmark: Old Method vs Hybrid (Bootstrap+VSR)   ║\u001b[0m\r\n"]
[0.000, "o", "\u001b[1m╚═══════════════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n  \u001b[1mOLD method:\u001b[0m    bootstrap + MEMORY.md = 29230 bytes (fixed, every turn)\r\n"]
[0.000, "o", "  \u001b[1mHYBRID method:\u001b[0m bootstrap + VSR search = 17498B fixed + ~1-2KB variable\r\n"]
[0.001, "o", "  \u001b[1mVSR store:\u001b[0m     17 files indexed (daily notes, knowledge base, docs)\r\n\r\n"]
[0.000, "o", "\r\n\u001b[1m#   TYPE         QUERY                                            OLD          HYBRID       SCORE\u001b[0m\r\n"]
