[0.000, "o", "\u001b[1mResults:\u001b[0m\r\n\r\n"]
[0.000, "o", "                    \u001b[1mOLD (bootstrap+MEMORY.md)    HYBRID (bootstrap+VSR)\u001b[0m\r\n"]
[0.000, "o", "  Recall:           14 / 20                       16 / 20\r\n"]
[0.000, "o", "  Bytes per turn:   29230                      ~18862\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "  \u001b[32mHybrid finds 2 more answers\u001b[0m (cross-file: daily notes, session transcripts)\r\n"]
[0.000, "o", "  \u001b[32mHybrid uses 10368 fewer bytes/turn (35% reduction)\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1mWhy:\u001b[0m\r\n"]
[0.000, "o", "  OLD loads MEMORY.md every turn (   11732B) but can't search daily notes\r\n"]
[0.000, "o", "  HYBRID replaces MEMORY.md with VSR search (~1-2KB relevant chunks)\r\n"]
[0.000, "o", "  VSR also searches across 17 workspace files (daily notes, docs, transcripts)\r\n\r\n"]
[0.000, "o", "\u001b[2mIDENTITY=USER.md/SOUL.md  FACTUAL=long-term-memory.md  CROSS=daily notes only  CONVENTION=CLAUDE.md\u001b[0m\r\n\r\n"]
