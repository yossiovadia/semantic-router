FROM python:3.11-slim
WORKDIR /app
COPY demo.html admin.html nb-demo.html demo-server.py ./
EXPOSE 8888
CMD ["python3", "demo-server.py", "--port", "8888", "--gateway", "http://vsr-gateway:8801", "--bbr-gateway", "http://bbr-gateway:8802", "--auth-gateway", "http://vsr-demo-gateway-openshift-default.openshift-ingress.svc.cluster.local:80"]
